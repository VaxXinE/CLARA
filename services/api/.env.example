# CLARA API local environment example.
# Copy to .env for local development only.
# Do not commit real .env files.
# DATABASE_URL below matches infra/local/docker-compose.yml only.
# It is not a production credential and must not be reused outside local development.
# Production expectations:
# - AUTH_MODE=provider
# - MOCK_AUTH_ENABLED=false
# - DATABASE_URL must be set to a real secret-managed value outside the repo
# - CORS_ORIGIN must be an explicit dashboard origin, never *
# - LOG_LEVEL should stay info or warn in production

NODE_ENV=development
APP_NAME=clara-api
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
AI_DRAFT_RATE_LIMIT_MAX=20
REPLY_SEND_RATE_LIMIT_MAX=30
REQUEST_BODY_LIMIT_BYTES=1048576
EMAIL_CHANNEL_MODE=disabled
GMAIL_PROVIDER_ENABLED=false
GMAIL_TOKEN_VAULT_MODE=mock
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_REDIRECT_URI=
GMAIL_OAUTH_REDIRECT_URI_ALLOWLIST=http://127.0.0.1:3000/internal/gmail/redirect
GMAIL_OAUTH_ALLOWED_SCOPES=gmail.readonly,gmail.send
GMAIL_TOKEN_ENCRYPTION_KEY=
TOKEN_VAULT_ENCRYPTION_KEY_BASE64=
TOKEN_VAULT_ENCRYPTION_KEY_VERSION=v1
AUTH_MODE=mock
AUTH_PROVIDER=
MOCK_AUTH_ENABLED=true
SUPABASE_AUTH_JWKS_URL=
SUPABASE_AUTH_ISSUER=
BETTER_AUTH_BASE_URL=
DATABASE_URL=postgresql://clara_user:clara_password_dev_only@127.0.0.1:5432/clara_api_dev
CORS_ORIGIN=http://127.0.0.1:5173
