# CLARA API local environment example.
# Copy to .env for local development only.
# Do not commit real .env files.
# DATABASE_URL below matches infra/local/docker-compose.yml only.
# It is not a production credential and must not be reused outside local development.
# Production expectations:
# - AUTH_MODE=provider
# - MOCK_AUTH_ENABLED=false
# - DATABASE_URL must be set to a real secret-managed value outside the repo
# - CORS_ORIGIN must be an explicit dashboard origin, never *
# - LOG_LEVEL should stay info or warn in production

NODE_ENV=development
APP_NAME=clara-api
HOST=127.0.0.1
PORT=3000
LOG_LEVEL=info
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=120
RATE_LIMIT_WINDOW_MS=60000
AI_DRAFT_RATE_LIMIT_MAX=20
REPLY_SEND_RATE_LIMIT_MAX=30
REQUEST_BODY_LIMIT_BYTES=1048576
EMAIL_CHANNEL_MODE=disabled
AI_PROVIDER_MODE=disabled
AI_PROVIDER=mock
AI_PROVIDER_API_KEY=
AI_MODEL_ALLOWLIST=
AI_DEFAULT_MODEL=
AI_REQUEST_TIMEOUT_MS=15000
AI_MAX_INPUT_CHARS=12000
AI_MAX_OUTPUT_TOKENS=1200
AI_DAILY_COST_BUDGET_CENTS=0
AI_WORKSPACE_DAILY_BUDGET_CENTS=0
AI_OPERATOR_DAILY_BUDGET_CENTS=0
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_APP_SECRET=
GMAIL_PROVIDER_ENABLED=false
GMAIL_TOKEN_VAULT_MODE=mock
GMAIL_OAUTH_CLIENT_ID=
GMAIL_OAUTH_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URI=
GMAIL_OAUTH_REDIRECT_URI_ALLOWLIST=http://127.0.0.1:3000/internal/gmail/redirect
GMAIL_OAUTH_ALLOWED_SCOPES=gmail.readonly,gmail.send
GMAIL_OAUTH_TOKEN_EXCHANGE_MODE=disabled
GMAIL_OAUTH_TOKEN_REFRESH_MODE=disabled
GMAIL_OAUTH_TOKEN_ENDPOINT=https://oauth2.googleapis.com/token
GMAIL_OAUTH_TOKEN_EXCHANGE_TIMEOUT_MS=10000
GMAIL_OAUTH_TOKEN_REFRESH_TIMEOUT_MS=10000
GMAIL_API_MODE=disabled
GMAIL_API_BASE_URL=
GMAIL_API_TIMEOUT_MS=10000
GMAIL_INBOUND_SYNC_SCHEDULER_ENABLED=false
GMAIL_INBOUND_SYNC_SCHEDULER_INTERVAL_MS=300000
GMAIL_INBOUND_SYNC_SCHEDULER_MAX_ACCOUNTS_PER_TICK=10
GMAIL_INBOUND_SYNC_SCHEDULER_MAX_MESSAGES_PER_ACCOUNT=25
GMAIL_TOKEN_ENCRYPTION_KEY=
TOKEN_VAULT_ENCRYPTION_KEY_BASE64=
TOKEN_VAULT_ENCRYPTION_KEY_VERSION=v1
AUTH_MODE=mock
AUTH_PROVIDER=
MOCK_AUTH_ENABLED=true
SUPABASE_AUTH_JWKS_URL=
SUPABASE_AUTH_ISSUER=
BETTER_AUTH_BASE_URL=
DATABASE_URL=postgresql://clara_user:clara_password_dev_only@127.0.0.1:5432/clara_api_dev
CORS_ORIGIN=http://127.0.0.1:5173

# Explicit first-owner bootstrap inputs for `npm run db:bootstrap-owner`.
# These are identifiers only, not provider tokens or secrets.
BOOTSTRAP_ORGANIZATION_ID=
BOOTSTRAP_ORGANIZATION_NAME=
BOOTSTRAP_WORKSPACE_ID=
BOOTSTRAP_WORKSPACE_NAME=
BOOTSTRAP_OWNER_PROVIDER_SUBJECT=
BOOTSTRAP_OWNER_EMAIL=
BOOTSTRAP_OWNER_DISPLAY_NAME=
