# Local dashboard environment example.
# Copy to .env.local for local development only.
# Keep demo mode as the default local behavior.
# Provider variables stay empty until you intentionally validate provider mode.
# Production expectations:
# - VITE_AUTH_MODE=provider
# - VITE_API_BASE_URL must point to the deployed API
# - VITE_SUPABASE_URL and VITE_SUPABASE_ANON_KEY must come from safe deployment config
# - Never place a Supabase service role key in this file

VITE_API_BASE_URL=http://127.0.0.1:3000
VITE_AUTH_MODE=demo
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
